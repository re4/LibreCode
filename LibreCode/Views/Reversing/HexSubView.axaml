<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rev="clr-namespace:LibreCode.Features.Reversing"
             x:Class="LibreCode.Views.Reversing.HexSubView"
             Background="#1e1e1e">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Go-to-offset bar -->
        <Border Grid.Row="0" Padding="8" Background="#252526"
                BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Offset (hex):" FontSize="11"
                           Foreground="#999" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="OffsetBox" Width="120"
                         FontSize="12" Background="#2d2d2d" Foreground="#d4d4d4"
                         Watermark="0" Text="0"/>
                <Button Grid.Column="3" Content="Go" Padding="8,4"
                        FontSize="11" Click="OnGoToOffsetClick"/>
            </Grid>
        </Border>

        <!-- Hex grid -->
        <ItemsControl Grid.Row="1" x:Name="HexList"
                      Background="#1e1e1e">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="rev:HexLine">
                    <Grid ColumnDefinitions="80,Auto,Auto" Margin="8,0">
                        <TextBlock Grid.Column="0" Text="{Binding OffsetHex}"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                   FontSize="12" Foreground="#569cd6"/>
                        <TextBlock Grid.Column="1" Text="{Binding HexPart}" Margin="12,0"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                   FontSize="12" Foreground="#d4d4d4"/>
                        <TextBlock Grid.Column="2" Text="{Binding AsciiPart}"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                   FontSize="12" Foreground="#4ec9b0"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Navigation -->
        <Border Grid.Row="2" Padding="8" Background="#252526"
                BorderBrush="#3c3c3c" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Grid.Column="0" Content="Prev" Padding="8,4"
                        FontSize="11" Click="OnPrevClick" Margin="0,0,4,0"/>
                <Button Grid.Column="1" Content="Next" Padding="8,4"
                        FontSize="11" Click="OnNextClick"/>
                <TextBlock Grid.Column="3" x:Name="PageLabel"
                           FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
