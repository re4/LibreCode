<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LibreCode.Views.Reversing.WasmAIAnalysisSubView"
             Background="#1e1e1e">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Controls -->
        <Border Grid.Row="0" Padding="8" Background="#252526"
                BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <TextBlock Text="AI WebAssembly Analysis"
                           FontSize="13" FontWeight="SemiBold" Foreground="#4ec9b0"/>
                <TextBlock Text="Sends the current WASM function disassembly to the AI for vulnerability analysis, logic explanation, and reverse engineering insights."
                           FontSize="11" Foreground="#999" TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" x:Name="CustomPrompt"
                             Watermark="Optional: add specific analysis instructions..."
                             FontSize="12" Background="#2d2d2d" Foreground="#d4d4d4"/>
                    <Button Grid.Column="1" x:Name="AnalyzeBtn"
                            Content="Analyze" Padding="12,4"
                            Margin="4,0,0,0" FontSize="11" Click="OnAnalyzeClick"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- AI response -->
        <ScrollViewer Grid.Row="1" x:Name="ResponseScroll" Padding="12">
            <TextBlock x:Name="ResponseText"
                       TextWrapping="Wrap" FontSize="12"
                       Foreground="#d4d4d4"
                       Text="Click 'Analyze' after loading a WASM binary and selecting a function in the Disassembly tab."/>
        </ScrollViewer>

        <!-- Status -->
        <Border Grid.Row="2" Padding="8" Background="#252526"
                BorderBrush="#3c3c3c" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusLabel" FontSize="11" Foreground="#999"/>
        </Border>
    </Grid>
</UserControl>
